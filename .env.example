# Copy file này thành `.env` và điền giá trị thật.
# `.env` được git-ignore; `.env.example` được commit làm template.

# API key cho LLM translator (đọc bởi translator_llm.py)
# - 9Router: dùng key bất kỳ (ví dụ: "sk-anything") nếu không yêu cầu auth
# - OpenRouter: lấy key tại https://openrouter.ai/keys
LLM_API_KEY=

# --- oneDNN / MKL-DNN (tăng tốc CPU Intel) ---
# PaddlePaddle tự bật oneDNN khi enable_mkldnn=True.
# Các biến dưới đây là TÙY CHỌN, chỉ cần set nếu muốn tinh chỉnh thêm.

# Cache oneDNN primitives giữa các lần chạy (giảm thời gian warmup).
# Đặt đường dẫn thư mục để lưu cache. Bỏ trống = không cache.
# ONEDNN_PRIMITIVE_CACHE_DIR=C:\Users\<you>\.onednn_cache

# Số lượng primitives tối đa giữ trong bộ nhớ (mặc định 1024, tăng nếu RAM dư).
# ONEDNN_PRIMITIVE_CACHE_CAPACITY=1024

# Verbose log oneDNN (debug): 0=tắt, 1=exec info, 2=chi tiết. Mặc định 0.
# ONEDNN_VERBOSE=0
